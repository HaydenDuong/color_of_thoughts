# Copy to `.env.local` (gitignored) and fill with Project Settings → API in Supabase.
# Never commit real keys.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Must match a row in `public.rooms.id` (seed migration inserts this default room).
VITE_DEFAULT_ROOM_ID=00000000-0000-4000-8000-000000000001
